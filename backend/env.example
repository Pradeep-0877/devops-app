# Application Settings
APP_NAME=Automation Platform
DEBUG=True
API_VERSION=v1
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Server
HOST=0.0.0.0
PORT=8000

# Database Configuration
DATABASE_TYPE=mongodb  # Options: mongodb, mysql

# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=automation_platform

# MySQL Configuration (if using MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=automation_user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=automation_platform

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# LDAP Authentication
LDAP_ENABLED=True
LDAP_SERVER=ldap://ldap.example.com:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_USER_DN=ou=users,dc=example,dc=com
LDAP_BIND_USER=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=your-ldap-password
LDAP_SEARCH_FILTER=(uid={username})

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Service Configuration
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Google Gemini (optional)
GOOGLE_API_KEY=your-google-api-key

# AI Provider (openai, anthropic, or google)
AI_PROVIDER=openai
